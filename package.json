{
  "name": "calendly",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run build:css && bun run --hot src/index.ts",
    "start": "bun run build:css && bun run src/index.ts",
    "seed": "bun run src/db/seed.ts",
    "build:css": "tailwindcss -i src/styles/globals.css -o src/styles/generated.css --minify",
    "watch:css": "tailwindcss -i src/styles/globals.css -o src/styles/generated.css --watch"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "wrangler": "^4.82.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "tailwindcss": "^4.2.2"
  }
}
